#!/bin/bash

# Enhanced Gitolite hook for repository creation with proper SSH key registration
# This hook registers a new repository with the Cache service AND gitolite SSH system

# Configuration
CACHE_BASE_URL="${LRCICD_CACHE_URL:-http://gitolite-cache:8081}"
REGISTER_TOKEN="$LRCICD_REGISTER_TOKEN"
REPO_NAME="$1"
GITOLITE_ADMIN_REPO="${GITOLITE_ADMIN_REPO:-$HOME/repositories/gitolite-admin.git}"
GITOLITE_ADMIN_WORKDIR="${GITOLITE_ADMIN_WORKDIR:-/tmp/gitolite-admin-$$}"

# Exit if required variables are missing
if [ -z "$REPO_NAME" ]; then
    echo "Error: Repository name required"
    exit 1
fi

if [ -z "$REGISTER_TOKEN" ]; then
    echo "Error: LRCICD_REGISTER_TOKEN environment variable required"
    exit 1
fi

# Generate SSH key pair for this repository's CI service
SSH_KEY_DIR="$HOME/.ssh/gitolite-ci"
mkdir -p "$SSH_KEY_DIR"

# Generate username for this repository's CI user
CI_USERNAME="ci-$REPO_NAME"
# Replace any slashes in repo name with dashes for username compatibility
CI_USERNAME=$(echo "$CI_USERNAME" | tr '/' '-')

KEY_NAME="ci-$REPO_NAME-$(date +%s)"
PRIVATE_KEY="$SSH_KEY_DIR/$KEY_NAME"
PUBLIC_KEY="$SSH_KEY_DIR/$KEY_NAME.pub"

# Generate SSH key pair
ssh-keygen -t rsa -b 2048 -f "$PRIVATE_KEY" -N "" -C "ci-user-$REPO_NAME" >/dev/null 2>&1

# Read the keys
SSH_PRIVATE_KEY=$(cat "$PRIVATE_KEY")
SSH_PUBLIC_KEY=$(cat "$PUBLIC_KEY")

# Step 1: Clone gitolite-admin repository
echo "Cloning gitolite-admin repository..."
git clone "$GITOLITE_ADMIN_REPO" "$GITOLITE_ADMIN_WORKDIR" >/dev/null 2>&1

if [ $? -ne 0 ]; then
    echo "Error: Failed to clone gitolite-admin repository"
    rm -f "$PRIVATE_KEY" "$PUBLIC_KEY"
    exit 1
fi

cd "$GITOLITE_ADMIN_WORKDIR"

# Step 2: Add the SSH public key to keydir
KEY_FILE="keydir/$CI_USERNAME@ci.pub"
echo "$SSH_PUBLIC_KEY" > "$KEY_FILE"

# Step 3: Update gitolite.conf to add the CI user with repository access
CONF_FILE="conf/gitolite.conf"

# Add the CI user to the repository with read/write access
{
    echo ""
    echo "# Auto-generated CI user for $REPO_NAME"
    echo "repo $REPO_NAME"
    echo "    RW+     =   $CI_USERNAME"
} >> "$CONF_FILE"

# Step 4: Commit and push the changes to gitolite-admin
echo "Updating gitolite configuration for CI user $CI_USERNAME..."
git add "$KEY_FILE" "$CONF_FILE"

git commit -m "Add CI user for repository $REPO_NAME
- User: $CI_USERNAME
- Key: $KEY_FILE
- Access: RW+ on $REPO_NAME
Auto-generated by temporalio-cicd hook" >/dev/null 2>&1

git push origin master >/dev/null 2>&1

if [ $? -ne 0 ]; then
    echo "Error: Failed to push gitolite-admin changes"
    cd /
    rm -rf "$GITOLITE_ADMIN_WORKDIR" "$PRIVATE_KEY" "$PUBLIC_KEY"
    exit 1
fi

echo "Successfully registered CI user $CI_USERNAME with gitolite"

# Step 5: Register repository with Cache service
echo "Registering repository $REPO_NAME with Cache service..."

# Construct the git URL using the CI user
GIT_URL="git@gitolite:$REPO_NAME.git"

RESPONSE=$(curl -s -w "\n%{http_code}" \
    -H "Authorization: Bearer $REGISTER_TOKEN" \
    -H "Content-Type: application/json" \
    -X PUT \
    "$CACHE_BASE_URL/sync/$REPO_NAME" \
    -d "{\"url\": \"$GIT_URL\", \"ssh-reading-private-key\": \"$SSH_PRIVATE_KEY\"}")

HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
RESPONSE_BODY=$(echo "$RESPONSE" | head -n -1)

if [ "$HTTP_CODE" -eq 200 ] || [ "$HTTP_CODE" -eq 201 ]; then
    echo "Repository $REPO_NAME successfully registered with Cache service"
    
    # Generate auth token for subsequent CI/CD operations
    CI_TOKEN=$(openssl rand -hex 32)
    
    # Store the CI token and username in git config for later use by post-receive hook
    git config --local "vaelci.ci-token" "$CI_TOKEN"
    git config --local "vaelci.ci-username" "$CI_USERNAME"
    
    echo "Generated CI token for repository: $CI_TOKEN"
    echo "CI username: $CI_USERNAME"
    echo "These will be used by the post-receive hook for CI/CD operations"
    
    # Clean up
    cd /
    rm -rf "$GITOLITE_ADMIN_WORKDIR" "$PRIVATE_KEY" "$PUBLIC_KEY"
    
    exit 0
else
    echo "Error registering repository with Cache service:"
    echo "HTTP $HTTP_CODE: $RESPONSE_BODY"
    
    # Attempt to rollback gitolite changes by removing the key and config
    cd "$GITOLITE_ADMIN_WORKDIR"
    git reset --hard HEAD~1 >/dev/null 2>&1
    git push -f origin master >/dev/null 2>&1
    cd /
    rm -rf "$GITOLITE_ADMIN_WORKDIR" "$PRIVATE_KEY" "$PUBLIC_KEY"
    
    exit 1
fi